---
import Layout from '@/layouts/Layout.astro'
import { manuscripts, publications } from '@/data/publications'

const sections = [
	{ title: 'Publications', items: publications },
	{ title: 'Manuscripts in Progress', items: manuscripts },
]

const highlightedAuthorPattern = /(Li,\s*Z\.?|Li\.\s*Z\.?|Z\.\s*Li|Zhimeng Li)/g
const highlightedAuthorExactPattern = /^(Li,\s*Z\.?|Li\.\s*Z\.?|Z\.\s*Li|Zhimeng Li)$/
const formatAuthors = (authors: string) =>
	authors.split(highlightedAuthorPattern).filter(Boolean).map((part) => ({
		text: part,
		highlight: highlightedAuthorExactPattern.test(part),
	}))
---

<Layout title='Zhimeng Li | Publications'>
	<section class='mb-12 max-w-3xl'>
		<p class='eyebrow'>Publications</p>
		<h1 class='mt-4 text-4xl font-semibold tracking-[-0.03em] text-academic-text md:text-5xl'>Publications</h1>
	</section>

	<div class='space-y-10'>
		{sections.map((section) => (
			<section>
				<div class='border-b border-academic-border pb-4'>
					<h2 class='text-2xl font-semibold tracking-tight text-academic-text'>{section.title}</h2>
				</div>
				<div class='mt-5 space-y-4'>
					{section.items.map((item) => (
						<article class='border-b border-academic-border pb-5'>
							<p class='leading-7 text-academic-text'>
								{formatAuthors(item.authors).map((part) => part.highlight ? <strong>{part.text}</strong> : part.text)} ({item.year}). {item.title}. {item.containerPrefix && `${item.containerPrefix} `}
								{item.venueTitle && <em>{item.venueTitle}</em>}{item.venueDetails && `, ${item.venueDetails}`}{item.publisher && `. ${item.publisher}`}{(item.venueTitle || item.publisher) && '.'}
							</p>

							{(item.abstract || item.pdf || item.website) && (
								<div class='mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm'>
									{item.abstract && (
										<details class='publication-details'>
											<summary class='cursor-pointer text-academic-accent underline decoration-academic-accent/30 underline-offset-4'>Abstract</summary>
											<p class='mt-3 max-w-3xl leading-7 text-academic-muted'>{item.abstract}</p>
										</details>
									)}
									{item.pdf && <a class='link-accent' href={item.pdf}>PDF</a>}
									{item.website && <a class='link-accent' href={item.website}>Website</a>}
								</div>
							)}
						</article>
					))}
				</div>
			</section>
		))}
	</div>
</Layout>
