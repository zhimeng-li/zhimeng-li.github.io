---
import Layout from '@/layouts/Layout.astro'
import { existsSync } from 'node:fs'
import { cv } from '@/data/cv'

const cvPdfExists = existsSync(new URL(`../../${cv.publicPath}`, import.meta.url))
---

<Layout title='Zhimeng Li | CV'>
	<section class='mb-12 max-w-3xl'>
		<p class='eyebrow'>CV</p>
		<h1 class='mt-4 text-4xl font-semibold tracking-[-0.03em] text-academic-text md:text-5xl'>CV</h1>
		<a class='academic-button mt-7' href={cv.pdfPath}>Download CV</a>
	</section>

	<section class='max-w-4xl border-t border-academic-border pt-6'>
		<div class='mt-6 min-h-[28rem] border border-academic-border bg-[#FFFDF9]'>
			{cvPdfExists ? (
				<iframe class='h-[70vh] min-h-[28rem] w-full' src={cv.pdfPath} title='Embedded CV PDF'></iframe>
			) : (
				<div class='flex min-h-[28rem] items-center justify-center px-6 text-center'>
					<p class='max-w-xl leading-8 text-academic-muted'>
						CV PDF placeholder. Add the file at <code>{cv.publicPath}</code> to show the embedded preview, or use the download link above once the file is available.
					</p>
				</div>
			)}
		</div>
	</section>
</Layout>
