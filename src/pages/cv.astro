---
import Layout from '@/layouts/Layout.astro'
import { education, experiences, skills, publications } from '../data/cv'
---

<Layout title='Zhimeng Li | CV'>
	<section class='mb-12 max-w-3xl'>
		<p class='eyebrow'>CV</p>
		<h1 class='mt-4 text-4xl font-semibold tracking-[-0.03em] text-academic-text md:text-5xl'>Curriculum vitae</h1>
		<p class='mt-5 text-lg leading-8 text-academic-muted'>
			A full CV will be added soon. This page currently includes placeholder sections only; the download button is ready for a future PDF at <code>public/Zhimeng_Li_CV.pdf</code>.
		</p>
		<a class='academic-button mt-7' href='/Zhimeng_Li_CV.pdf'>Download CV</a>
	</section>

	<div class='grid gap-6 lg:grid-cols-2'>
		<section class='academic-card'>
			<h2 class='text-2xl font-semibold tracking-tight text-academic-text'>Education</h2>
			{education.map((item) => (
				<div class='mt-5 border-t border-academic-border pt-5'>
					<p class='text-sm font-semibold uppercase tracking-[0.18em] text-academic-accent'>{item.time}</p>
					<p class='mt-2 font-semibold'>{item.degree}</p>
					<p class='text-academic-muted'>{item.school}</p>
					<p class='mt-3 leading-7 text-academic-muted'>{item.description}</p>
				</div>
			))}
		</section>

		<section class='academic-card'>
			<h2 class='text-2xl font-semibold tracking-tight text-academic-text'>Experience</h2>
			{experiences.map((item) => (
				<div class='mt-5 border-t border-academic-border pt-5'>
					<p class='text-sm font-semibold uppercase tracking-[0.18em] text-academic-accent'>{item.time}</p>
					<p class='mt-2 font-semibold'>{item.title}</p>
					<p class='text-academic-muted'>{item.company}</p>
					<p class='mt-3 leading-7 text-academic-muted'>{item.description}</p>
				</div>
			))}
		</section>

		<section class='academic-card'>
			<h2 class='text-2xl font-semibold tracking-tight text-academic-text'>Publications</h2>
			{publications.map((item) => (
				<div class='mt-5 border-t border-academic-border pt-5'>
					<p class='leading-7'>{item.authors}. {item.time}. {item.title}. {item.journal}.</p>
					<p class='mt-2 text-sm text-academic-muted'>TODO: Replace with verified citation details.</p>
				</div>
			))}
		</section>

		<section class='academic-card'>
			<h2 class='text-2xl font-semibold tracking-tight text-academic-text'>Skills and research methods</h2>
			{skills.map((item) => (
				<div class='mt-5 border-t border-academic-border pt-5'>
					<p class='font-semibold'>{item.title}</p>
					<p class='mt-2 leading-7 text-academic-muted'>{item.description}</p>
				</div>
			))}
		</section>
	</div>
</Layout>
