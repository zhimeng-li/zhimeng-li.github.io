---
import Layout from '@/layouts/Layout.astro'
import { existsSync } from 'node:fs'

const cvPath = '/Zhimeng_Li_CV.pdf'
const cvPdfExists = existsSync(new URL('../../public/Zhimeng_Li_CV.pdf', import.meta.url))
---

<Layout title='Zhimeng Li | CV'>
	<section class='mb-12 max-w-3xl'>
		<p class='eyebrow'>CV</p>
		<h1 class='mt-4 text-4xl font-semibold tracking-[-0.03em] text-academic-text md:text-5xl'>CV</h1>
		<p class='mt-5 text-lg leading-8 text-academic-muted'>
			A full CV will be added soon. The download link and embedded preview are prepared for a future PDF at <code>public/Zhimeng_Li_CV.pdf</code>.
		</p>
		<a class='academic-button mt-7' href={cvPath}>Download CV</a>
	</section>

	<section class='max-w-4xl border-t border-academic-border pt-6'>
		<h2 class='text-2xl font-semibold tracking-tight text-academic-text'>CV preview</h2>
		<p class='mt-3 leading-8 text-academic-muted'>
			The embedded CV will display here once the PDF is added to <code>public/Zhimeng_Li_CV.pdf</code>.
		</p>

		<div class='mt-6 min-h-[28rem] border border-academic-border bg-[#FFFDF9]'>
			{cvPdfExists ? (
				<iframe class='h-[70vh] min-h-[28rem] w-full' src={cvPath} title='Embedded CV PDF'></iframe>
			) : (
				<div class='flex min-h-[28rem] items-center justify-center px-6 text-center'>
					<p class='max-w-xl leading-8 text-academic-muted'>
						CV PDF placeholder. Add the file at <code>public/Zhimeng_Li_CV.pdf</code> to show the embedded preview, or use the download link above once the file is available.
					</p>
				</div>
			)}
		</div>
	</section>
</Layout>
