---
import Layout from '@/layouts/Layout.astro'
import { research } from '@/data/research'

const highlightedAuthorPattern = /(Li,\s*Z\.?|Li\.\s*Z\.?|Z\.\s*Li|Zhimeng Li)/g
const highlightedAuthorExactPattern = /^(Li,\s*Z\.?|Li\.\s*Z\.?|Z\.\s*Li|Zhimeng Li)$/
const formatAuthors = (authors: string) =>
	authors.split(highlightedAuthorPattern).filter(Boolean).map((part) => ({
		text: part,
		highlight: highlightedAuthorExactPattern.test(part),
	}))
---

<Layout title='Zhimeng Li | Research'>
	<section class='mb-12 max-w-3xl'>
		<p class='eyebrow'>Research</p>
		<h1 class='mt-4 text-4xl font-semibold tracking-[-0.03em] text-academic-text md:text-5xl'>Research</h1>
		<p class='mt-5 text-lg leading-8 text-academic-muted'>{research.intro}</p>
	</section>

	<div class='max-w-4xl space-y-12'>
		{research.sections.map((section, index) => (
			<article class='border-t border-academic-border pt-7'>
				<div class='text-sm font-semibold text-academic-accent'>0{index + 1}</div>
				<div>
					<h2 class='mt-3 text-2xl font-semibold tracking-tight text-academic-text'>{section.title}</h2>
					<p class='mt-2 text-base font-medium leading-7 text-academic-text/75'>{section.guidingQuestion}</p>
					<div class='mt-4 space-y-3 text-[1.02rem] leading-8 text-academic-muted'>
						{section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
					</div>
					{section.relatedWork.length > 0 && (
						<div class='mt-6 border-l-2 border-academic-border pl-4'>
							<h3 class='text-sm font-semibold uppercase tracking-[0.16em] text-academic-accent'>Related work</h3>
							<ul class='mt-3 space-y-2 text-sm leading-7 text-academic-muted'>
								{section.relatedWork.map((work) => (
									<li>
										{formatAuthors(work.authors).map((part) => part.highlight ? <strong>{part.text}</strong> : part.text)} ({work.year}). {work.title}. {work.containerPrefix && `${work.containerPrefix} `}
										{work.venueTitle && <em>{work.venueTitle}</em>}{work.venueDetails && `, ${work.venueDetails}`}{work.publisher && `. ${work.publisher}`}{(work.venueTitle || work.publisher) && '.'}
									</li>
								))}
							</ul>
						</div>
					)}
				</div>
			</article>
		))}
	</div>
</Layout>
