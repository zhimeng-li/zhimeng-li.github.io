---
import Layout from '@/layouts/Layout.astro'

const researchSections = [
	{
		title: 'Emotion segmentation',
		description: [
			'This placeholder section can describe research on how people parse continuous behavior, bodily information, and social context into meaningful emotional moments.',
			'Future text can explain the guiding questions and methods used to study emotion perception without listing unconfirmed findings, sample sizes, datasets, or paper titles.',
		],
	},
	{
		title: 'Cross-cultural emotion perception',
		description: [
			'This placeholder section can describe interests in how emotion perception is shaped by cultural contexts, social expectations, and shared interpretive practices.',
			'It should later be replaced with specific, verified project descriptions while avoiding unsupported claims about cultural differences or generalizability.',
		],
	},
	{
		title: 'Emotion concepts and language',
		description: [
			'This placeholder section can describe work on how language and emotion concepts help people organize affective experience and infer what others are feeling.',
			'Future content can mention confirmed behavioral, text-analytic, or conceptual approaches when those details are ready for public presentation.',
		],
	},
	{
		title: 'Empathy and intergroup understanding',
		description: [
			'This placeholder section can describe interests in how people understand and respond to others’ emotional experiences across social boundaries.',
			'Later revisions can connect this area to social perception, social inference, and empathy while keeping sensitive participant, student, or collaborator details private.',
		],
	},
]
---

<Layout title='Zhimeng Li | Research'>
	<section class='mb-12 max-w-3xl'>
		<p class='eyebrow'>Research</p>
		<h1 class='mt-4 text-4xl font-semibold tracking-[-0.03em] text-academic-text md:text-5xl'>Research areas</h1>
		<p class='mt-5 text-lg leading-8 text-academic-muted'>
			This first-draft page outlines broad research directions in affective science and social psychology. The text is intentionally general and should be replaced with verified project descriptions when ready.
		</p>
	</section>

	<div class='grid gap-5'>
		{researchSections.map((section, index) => (
			<article class='academic-card grid gap-5 lg:grid-cols-[4rem_1fr]'>
				<div class='text-sm font-semibold text-academic-accent'>0{index + 1}</div>
				<div>
					<h2 class='text-2xl font-semibold tracking-tight text-academic-text'>{section.title}</h2>
					<div class='mt-4 space-y-3 text-[1.02rem] leading-8 text-academic-muted'>
						{section.description.map((paragraph) => <p>{paragraph}</p>)}
					</div>
				</div>
			</article>
		))}
	</div>
</Layout>
