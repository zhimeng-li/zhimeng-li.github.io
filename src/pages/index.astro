---
import Layout from '../layouts/Layout.astro'

const updates = [
	'TODO: Add a dated update when a publication, presentation, or website milestone is ready to announce.',
	'TODO: Add future news items after details are confirmed for public sharing.',
]
---

<Layout title='Zhimeng Li | Home'>
	<section class='max-w-3xl pt-4 md:pt-10'>
		<p class='text-[1.08rem] leading-8 text-academic-text/90 md:text-lg md:leading-9'>
			I am a PhD candidate in Psychology at Yale University, working with <a class='link-accent' href='https://www.mariagendronphd.com/'>Dr. Maria Gendron</a> in the <a class='link-accent' href='https://asclab.yale.edu/'>Affective Science and Culture Lab</a>. My research examines how people identify and make meaning of emotions, and how body, language, and culture scaffold these processes. I use behavioral experiments, naturalistic video paradigms, computational text analysis, and physiological measures to study emotion perception across contexts. Previously, I obtained a BA in Psychology and Comparative Literature from Cornell University, where I worked with <a class='link-accent' href='https://lauraniemi.com/'>Dr. Laura Niemi</a>, <a class='link-accent' href='https://blogs.cornell.edu/paclab/'>Dr. Vivian Zayas</a>, and <a class='link-accent' href='https://www.aclab.human.cornell.edu/People.html'>Dr. Adam Anderson</a>.
		</p>
	</section>

	<section class='mt-14 max-w-3xl border-t border-academic-border pt-8'>
		<h2 class='text-xl font-semibold tracking-tight text-academic-text'>Updates</h2>
		<!-- TODO: Replace with dated, verified updates. -->
		<ul class='mt-5 list-disc space-y-3 pl-5 text-academic-muted marker:text-academic-accent/70'>
			{updates.map((update) => <li class='leading-7'>{update}</li>)}
		</ul>
	</section>
</Layout>
