---
import Layout from '@/layouts/Layout.astro'

const sections = [
	{
		title: 'Teaching experience',
		text: 'Placeholder teaching entry. Replace with verified teaching assistantships, guest lectures, workshops, course roles, terms, and institutions when they are ready to publish.',
	},
	{
		title: 'Mentoring',
		text: 'Placeholder mentoring section. Future text can describe mentoring philosophy, general mentoring activities, or opportunities for students without listing private or sensitive student information.',
	},
	{
		title: 'Teaching interests',
		text: 'Placeholder teaching interests may include broad areas such as emotion, culture, language, social perception, research methods, and social psychology. Replace with a concise, accurate teaching statement when ready.',
	},
]
---

<Layout title='Zhimeng Li | Teaching'>
	<section class='mb-12 max-w-3xl'>
		<p class='eyebrow'>Teaching</p>
		<h1 class='mt-4 text-4xl font-semibold tracking-[-0.03em] text-academic-text md:text-5xl'>Teaching and mentoring</h1>
		<p class='mt-5 text-lg leading-8 text-academic-muted'>
			This page is a placeholder for future teaching and mentoring information. Add only confirmed courses, roles, dates, institutions, teaching awards, and mentoring details when ready.
		</p>
	</section>

	<div class='grid gap-5'>
		{sections.map((section) => (
			<section class='academic-card'>
				<h2 class='text-2xl font-semibold tracking-tight text-academic-text'>{section.title}</h2>
				<!-- TODO: Replace with verified teaching or mentoring content. -->
				<p class='mt-4 leading-8 text-academic-muted'>{section.text}</p>
			</section>
		))}
	</div>
</Layout>
