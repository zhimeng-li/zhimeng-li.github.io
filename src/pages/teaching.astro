---
import Layout from '@/layouts/Layout.astro'
import { graduateTeachingFellow, guestLecturer, instructor, undergraduateTeachingAssistant } from '@/data/teaching'

const sections = [
	{ title: 'Instructor', entries: instructor },
	{ title: 'Guest Lecturer', entries: guestLecturer },
	{ title: 'Graduate Teaching Fellow', entries: graduateTeachingFellow },
	{ title: 'Undergraduate Teaching Assistant', entries: undergraduateTeachingAssistant },
]
---

<Layout title='Zhimeng Li | Teaching'>
	<section class='mb-12 max-w-3xl'>
		<p class='eyebrow'>Teaching</p>
		<h1 class='mt-4 text-4xl font-semibold tracking-[-0.03em] text-academic-text md:text-5xl'>Teaching</h1>
	</section>

	<div class='max-w-3xl space-y-10'>
		{sections.map((section) => (
			<section class='border-t border-academic-border pt-6'>
				<h2 class='text-2xl font-semibold tracking-tight text-academic-text'>{section.title}</h2>
				<div class='mt-5 space-y-6'>
					{section.entries.map((entry) => (
						<article>
							<h3 class='text-lg font-semibold tracking-tight text-academic-text'>{entry.title}</h3>
							<dl class='mt-2 space-y-1 text-sm leading-6 text-academic-muted'>
								{entry.term && (
									<div>
										<dt class='inline font-semibold text-academic-text/75'>Term: </dt>
										<dd class='inline'>{entry.term}</dd>
									</div>
								)}
								{entry.institution && (
									<div>
										<dt class='inline font-semibold text-academic-text/75'>Institution: </dt>
										<dd class='inline'>{entry.institution}</dd>
									</div>
								)}
								{entry.instructor && (
									<div>
										<dt class='inline font-semibold text-academic-text/75'>Instructor: </dt>
										<dd class='inline'>{entry.instructor}</dd>
									</div>
								)}
							</dl>
							{entry.description && (
								<details class='mt-3 border-l-2 border-academic-border pl-4'>
									<summary class='cursor-pointer text-sm font-medium text-academic-accent underline decoration-academic-accent/30 underline-offset-4'>Course description</summary>
									<div class='mt-3 space-y-3 leading-8 text-academic-muted'>
										{entry.description.map((paragraph) => <p>{paragraph}</p>)}
									</div>
								</details>
							)}
						</article>
					))}
				</div>
			</section>
		))}
	</div>
</Layout>
