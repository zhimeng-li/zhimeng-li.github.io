---
import { ClientRouter } from 'astro:transitions'

import Navbar from '../components/ui/Navbar.astro'
import Head from '../components/Head.astro'

import { seo, template } from '../settings'
import Footer from '../components/ui/Footer.astro'

type Props = {
	title?: string
	description?: string
	image?: string
}

const {
	title = seo.default_title,
	description = seo.default_description,
	image = seo.default_image,
} = Astro.props
---

<!doctype html>
<html lang='en' data-theme={template.lightTheme}>
	<head>
		{template.transitions && <ClientRouter />}
		<Head title={title} description={description} image={image} />
	</head>
	<body>
		<div class={`min-h-screen bg-academic-background text-academic-text drawer lg:drawer-open ${template.menu_left ? 'drawer-end' : ''}`}>
			<input id='my-drawer' type='checkbox' class='drawer-toggle' />
			<div class='drawer-content min-h-screen'>
				<header class='sticky top-0 z-50 border-b border-academic-border bg-academic-background/95 backdrop-blur lg:hidden'>
					<div class='navbar mx-auto max-w-5xl px-4'>
						<div class='navbar-start'>
							<label for='my-drawer' class='btn btn-square btn-ghost text-academic-accent' aria-label='Open navigation'>
								<svg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 24 24' stroke-width='1.5' class='size-6 stroke-current'>
									<path stroke-linecap='round' stroke-linejoin='round' d='M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5'></path>
								</svg>
							</label>
						</div>
						<a href='/' class='navbar-center text-sm font-semibold uppercase tracking-[0.18em] text-academic-accent'>Zhimeng Li</a>
						<div class='navbar-end'></div>
					</div>
				</header>
				<main class='mx-auto flex min-h-screen max-w-6xl flex-col px-5 py-8 md:px-10 lg:px-14 lg:py-14'>
					<div class='grow'>
						<slot />
					</div>
					<Footer />
				</main>
			</div>
			<div class='drawer-side z-40'>
				<label for='my-drawer' aria-label='close sidebar' class='drawer-overlay'></label>
				<Navbar />
			</div>
		</div>
	</body>
</html>

<style is:global>
	:root {
		--academic-bg: #faf9f6;
		--academic-panel: #fffdfa;
		--academic-soft: #f4f2ee;
		--academic-text: #1f2933;
		--academic-muted: #6b7280;
		--academic-accent: #286dc0;
		--academic-accent-dark: #1f4f86;
		--academic-border: #e5e7eb;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
		background: var(--academic-bg);
		color: var(--academic-text);
		font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	}

	::selection {
		background: rgba(40, 109, 192, 0.18);
	}

	a {
		color: inherit;
	}

	.eyebrow {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: var(--academic-accent);
	}

	.hero-panel {
		border: 1px solid var(--academic-border);
		border-radius: 2rem;
		background:
			linear-gradient(135deg, rgba(255,255,255,0.82), rgba(250,249,246,0.92)),
			radial-gradient(circle at top right, rgba(40,109,192,0.13), transparent 32rem);
		padding: clamp(2rem, 5vw, 4rem);
		box-shadow: 0 24px 70px rgba(31, 41, 51, 0.06);
	}

	.academic-card {
		border: 1px solid var(--academic-border);
		border-radius: 1.25rem;
		background: rgba(255, 253, 250, 0.78);
		padding: 1.5rem;
		box-shadow: 0 12px 36px rgba(31, 41, 51, 0.04);
	}

	.academic-section {
		display: grid;
		gap: 2rem;
		border-bottom: 1px solid var(--academic-border);
		padding: 3.5rem 0;
	}

	@media (min-width: 1024px) {
		.academic-section {
			grid-template-columns: 13rem minmax(0, 1fr);
		}
	}

	.academic-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 9999px;
		background: var(--academic-accent);
		color: white;
		font-weight: 650;
		padding: 0.8rem 1.2rem;
		transition: background 160ms ease, transform 160ms ease;
	}

	.academic-button:hover {
		background: var(--academic-accent-dark);
		transform: translateY(-1px);
	}

	.prose a,
	.link-accent {
		color: var(--academic-accent);
		text-decoration-line: underline;
		text-decoration-color: rgba(40, 109, 192, 0.32);
		text-underline-offset: 0.22em;
	}

	.prose a:hover,
	.link-accent:hover {
		color: var(--academic-accent-dark);
	}
</style>
