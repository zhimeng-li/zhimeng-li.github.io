---
import { social } from '@/settings'

const { fullName, title, institute } = Astro.props
---

<section class='hero-panel'>
	<div class='max-w-4xl'>
		<p class='eyebrow'>Affective scientist · Social psychologist</p>
		<h1 class='mt-5 max-w-3xl text-5xl font-semibold leading-[1.05] tracking-[-0.04em] text-academic-text md:text-6xl'>
			{fullName}
		</h1>
		<p class='mt-5 text-xl leading-8 text-academic-muted'>{title} at {institute}</p>
		<p class='mt-9 max-w-3xl text-xl leading-9 text-academic-text/85'>
			I am a PhD candidate in Psychology at Yale University. My research examines how people identify and make meaning of emotions, and how body, language, and culture scaffold these processes. I use behavioral experiments, naturalistic video paradigms, computational text analysis, and physiological measures to study emotion perception across contexts.
		</p>
		<div class='mt-9 flex flex-wrap items-center gap-4'>
			<a class='academic-button' href='/research'>Read about research</a>
			<a class='link-accent text-sm font-medium' href={`mailto:${social.email}`}>{social.email}</a>
		</div>
	</div>
</section>
