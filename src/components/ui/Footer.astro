---
import { profile, social } from '../../settings'

const { fullName } = profile
---

<footer class='mt-16 border-t border-academic-border py-8 text-sm text-academic-muted'>
	<div class='flex flex-col gap-2 md:flex-row md:items-center md:justify-between'>
		<p>© {new Date().getFullYear()} {fullName}.</p>
		<a class='link-accent' href={`mailto:${social.email}`}>{social.email}</a>
	</div>
	<p class='mt-2 text-xs'>First-draft academic website built with Astro Academia and deployed through GitHub Pages Actions.</p>
</footer>
