---
import { profile, social, template } from '../../settings'

const { fullName, title, institute } = profile
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/'
const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/research', label: 'Research' },
	{ href: '/publications', label: 'Publications' },
	{ href: '/teaching', label: 'Teaching' },
	{ href: '/cv', label: 'CV' },
]
---

<aside class='flex h-screen w-[19rem] flex-col border-r border-academic-border bg-[#F4F2EE]/95 px-8 py-10 text-academic-text'>
	<div class='flex grow flex-col'>
		<a href={`${template.base}/`} class='group block text-center'>
			<img class='mx-auto aspect-square w-40 border border-academic-border object-cover lg:w-[13.75rem]' src={`${template.base}/images/headshot.jpg`} alt='Zhimeng Li headshot' />
			<h1 class='mt-7 text-[2.15rem] font-semibold leading-tight tracking-tight'>{fullName}</h1>
			<p class='mt-3 text-lg leading-7 text-academic-muted'>{title}</p>
		</a>

		<nav class='mt-11 border-t border-academic-border pt-6' aria-label='Primary navigation'>
			<ul class='space-y-1'>
				{navItems.map((item) => {
					const active = currentPath === item.href
					return (
						<li>
							<a
								href={`${template.base}${item.href}`}
								aria-current={active ? 'page' : undefined}
								class:list={[
									'block border-l-2 px-3 py-2.5 text-base font-medium transition',
									active
										? 'border-academic-accent text-academic-accent'
										: 'border-transparent text-academic-text/75 hover:border-academic-border hover:text-academic-accent',
								]}
							>
								{item.label}
							</a>
						</li>
					)
				})}
			</ul>
		</nav>
	</div>

	<div class='border-t border-academic-border pt-6 text-base text-academic-muted'>
		<p class='mb-2 text-sm font-semibold uppercase tracking-[0.16em]'>Contact</p>
		<a class='link-accent break-all leading-7' href={`mailto:${social.email}`}>{social.email}</a>
	</div>
</aside>
