---
import { profile, social, template } from '../../settings'

const { fullName, title, institute } = profile
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/'
const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/research', label: 'Research' },
	{ href: '/publications', label: 'Publications' },
	{ href: '/teaching', label: 'Teaching' },
	{ href: '/cv', label: 'CV' },
]
---

<aside class='flex h-screen w-[17rem] flex-col border-r border-academic-border bg-[#F4F2EE]/95 px-7 py-9 text-academic-text'>
	<div class='flex grow flex-col'>
		<a href={`${template.base}/`} class='group block'>
			<div class='flex aspect-[4/5] w-36 items-center justify-center border border-academic-border bg-academic-background text-2xl font-semibold tracking-[0.16em] text-academic-muted/70' aria-label='Headshot placeholder'>
				ZL
			</div>
			<h1 class='mt-6 text-2xl font-semibold leading-tight tracking-tight'>{fullName}</h1>
			<p class='mt-3 text-sm leading-6 text-academic-muted'>{title}<br />{institute}</p>
		</a>

		<nav class='mt-11 border-t border-academic-border pt-6' aria-label='Primary navigation'>
			<ul class='space-y-0.5'>
				{navItems.map((item) => {
					const active = currentPath === item.href
					return (
						<li>
							<a
								href={`${template.base}${item.href}`}
								aria-current={active ? 'page' : undefined}
								class:list={[
									'block border-l-2 px-3 py-2 text-sm font-medium transition',
									active
										? 'border-academic-accent text-academic-accent'
										: 'border-transparent text-academic-text/75 hover:border-academic-border hover:text-academic-accent',
								]}
							>
								{item.label}
							</a>
						</li>
					)
				})}
			</ul>
		</nav>
	</div>

	<div class='border-t border-academic-border pt-6 text-sm text-academic-muted'>
		<p class='mb-2 text-xs font-semibold uppercase tracking-[0.18em]'>Contact</p>
		<a class='link-accent break-all' href={`mailto:${social.email}`}>{social.email}</a>
	</div>
</aside>
