---
import { profile, social, template } from '../../settings'

const { fullName, title, institute } = profile
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/'
const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/research', label: 'Research' },
	{ href: '/publications', label: 'Publications' },
	{ href: '/teaching', label: 'Teaching' },
	{ href: '/cv', label: 'CV' },
]
---

<aside class='flex h-screen w-[18rem] flex-col border-r border-academic-border bg-[#F4F2EE]/95 px-7 py-9 text-academic-text'>
	<div class='flex grow flex-col'>
		<a href={`${template.base}/`} class='group block'>
			<p class='text-xs font-semibold uppercase tracking-[0.28em] text-academic-accent'>Academic website</p>
			<h1 class='mt-5 text-3xl font-semibold leading-tight tracking-tight'>{fullName}</h1>
			<p class='mt-3 text-sm leading-6 text-academic-muted'>{title}<br />{institute}</p>
		</a>

		<div class='mt-8 rounded-2xl border border-academic-border bg-academic-background/80 p-4'>
			<p class='text-xs font-semibold uppercase tracking-[0.22em] text-academic-muted'>Research focus</p>
			<p class='mt-3 text-sm leading-6'>Affective science, social psychology, emotion, culture, language, social perception, inference, and empathy.</p>
		</div>

		<nav class='mt-10' aria-label='Primary navigation'>
			<ul class='space-y-1'>
				{navItems.map((item) => {
					const active = currentPath === item.href
					return (
						<li>
							<a
								href={`${template.base}${item.href}`}
								aria-current={active ? 'page' : undefined}
								class:list={[
									'block rounded-xl border px-3 py-2.5 text-sm font-medium transition',
									active
										? 'border-academic-accent/25 bg-academic-accent/10 text-academic-accent'
										: 'border-transparent text-academic-text/75 hover:border-academic-border hover:bg-academic-background hover:text-academic-accent',
								]}
							>
								{item.label}
							</a>
						</li>
					)
				})}
			</ul>
		</nav>
	</div>

	<div class='border-t border-academic-border pt-6 text-sm text-academic-muted'>
		<p class='mb-2 text-xs font-semibold uppercase tracking-[0.22em]'>Contact</p>
		<a class='link-accent break-all' href={`mailto:${social.email}`}>{social.email}</a>
	</div>
</aside>
